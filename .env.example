# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string (e.g. from Neon, Supabase, or Railway).
# For serverless/Vercel add ?pgbouncer=true&connection_limit=1 if using a pooler.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ADMIN_PASSWORD: Password used to access /admin and /admin/:storeSlug dashboards.
# Set this in Vercel Environment Variables — never commit the real value here.
ADMIN_PASSWORD="change_me_before_deploying"
